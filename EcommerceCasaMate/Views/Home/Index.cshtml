@model IEnumerable<EcommerceCasaMate.Models.Producto>

@{
    ViewData["Title"] = "Catálogo - La Casa del Mate";
}

<div class="text-center mb-5">
    <h2 class="display-5 fw-bold">Productos Regionales</h2>
    <hr class="w-25 mx-auto" />
</div>

<div class="container">
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm text-center border-0" style="background-color: #f8f9fa;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold mt-2">@item.Nombre</h5>

                        <div class="mb-3">
                            <span class="badge rounded-pill text-bg-warning text-white">
                                @item.IdCategoriaNavigation?.NombreCategoria
                            </span>
                        </div>

                        <p class="card-text text-muted small mt-auto mb-4">
                        </p>

                        <h3 class="text-success fw-bold mb-3">$ @item.Precio.ToString("N2")</h3>

                        <p class="text-muted small mb-4">Stock: @item.Stock unidades</p>

                        <a href="#" class="btn btn-primary w-100 fw-bold mt-auto">
                            Agregar al Carrito
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>