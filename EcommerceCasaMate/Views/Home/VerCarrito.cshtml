@model IEnumerable<EcommerceCasaMate.Models.ItemCarrito>

@{
    ViewData["Title"] = "Detalle de Compra";
}

<div class="container mt-5 mb-5">
    <h2 class="mb-4">Mi Carrito de Compras 🛒</h2>
    <hr />

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center mt-4">
            <h4>Tu carrito está vacío</h4>
            <p>¡Todavía no agregaste ningún producto regional!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Volver al Catálogo</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Producto</th>
                        <th>Precio</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.NombreProducto</td>
                            <td>$ @item.Precio.ToString("N2")</td>
                            <td>@item.Cantidad</td>
                            <td class="fw-bold text-success">$ @item.Subtotal.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 p-3 bg-light border rounded">
            <div>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary text-white fw-bold">
                    Seguir Comprando
                </a>
            </div>
            <div class="text-end">
                <h3 class="mb-3">Total a Pagar: <span class="text-success fw-bold">$ @Model.Sum(i => i.Subtotal).ToString("N2")</span></h3>
                <a href="#" class="btn btn-success fw-bold px-4 py-2">Proceder al Pago</a>
            </div>
        </div>
    }
</div>