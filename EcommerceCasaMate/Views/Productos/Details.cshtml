@model EcommerceCasaMate.Models.Producto

@{
    ViewData["Title"] = "Detalles del Producto";
}

<h1>Detalles del Producto</h1>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-3 fw-bold">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>

        <dt class="col-sm-3 fw-bold">Precio</dt>
        <dd class="col-sm-9">$ @Model.Precio</dd>

        <dt class="col-sm-3 fw-bold">Stock Disponible</dt>
        <dd class="col-sm-9">@Model.Stock unidades</dd>
    </dl>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model?.IdProducto" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Volver a la lista</a>
</div>