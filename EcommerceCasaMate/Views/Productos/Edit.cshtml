@model EcommerceCasaMate.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<h1>Editar Producto</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="IdProducto" />

            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label fw-bold">Nombre del Producto</label>
                <input asp-for="Nombre" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Precio" class="control-label fw-bold">Precio</label>
                <input asp-for="Precio" type="number" step="0.01" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Stock" class="control-label fw-bold">Stock</label>
                <input asp-for="Stock" type="number" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="IdCategoria" class="control-label fw-bold">Categoría</label>
                <select asp-for="IdCategoria" class="form-select" asp-items="ViewBag.ListaCategorias">
                    <option value="">-- Seleccionar Categoría --</option>
                </select>
            </div>

            <div class="form-group">
                <input type="submit" value="Guardar Cambios" class="btn btn-warning" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>