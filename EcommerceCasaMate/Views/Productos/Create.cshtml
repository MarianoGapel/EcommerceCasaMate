@model EcommerceCasaMate.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<h1>Crear Nuevo Producto</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label fw-bold">Nombre del Producto</label>
                <input asp-for="Nombre" class="form-control" />
            </div>
            <div class="form-group mb-4">
                <label asp-for="IdCategoria" class="control-label fw-bold">Categoría</label>
                <select asp-for="IdCategoria" class="form-select" asp-items="ViewBag.ListaCategorias">
                    <option value="">-- Seleccionar Categoría --</option>
                </select>
            </div>

            <div class="form-group">
                <input type="submit" value="Guardar Producto" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>